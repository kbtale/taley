{
	"name": "taley",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"db:bootstrap": "bun run scripts/db-bootstrap.ts",
		"dev": "bun run db:bootstrap && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run && bun run test:e2e",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@iconify-json/lucide": "^1.2.100",
		"@playwright/test": "^1.58.2",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^24",
		"@unocss/preset-icons": "^66.6.7",
		"@unocss/preset-web-fonts": "^66.6.7",
		"@vitest/browser-playwright": "^4.1.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.54.0",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"unocss": "^66.6.7",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"surrealdb": "^2.0.3",
		"svelvet": "^11.0.5",
		"zod": "^4.3.6",
		"zod-to-json-schema": "^3.25.2"
	}
}
